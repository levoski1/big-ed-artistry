{
  "name": "big-ed-artistry",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:login": "npx supabase login",
    "db:link": "npx supabase link --project-ref $SUPABASE_PROJECT_REF",
    "db:migrate": "npx supabase db push",
    "db:backup": "pg_dump $DATABASE_URL -f supabase/backups/backup_$(date +%Y%m%d_%H%M%S).sql",
    "db:backup:data": "pg_dump $DATABASE_URL --data-only -f supabase/backups/data_$(date +%Y%m%d_%H%M%S).sql",
    "db:types": "npx supabase gen types typescript --project-id $SUPABASE_PROJECT_REF | grep -q 'export' && npx supabase gen types typescript --project-id $SUPABASE_PROJECT_REF > src/lib/types/database.ts || echo 'Type generation failed \u2014 keeping existing types'",
    "admin:create": "npx tsx scripts/create-admin.ts",
    "test": "jest"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "next": "14.2.5",
    "react": "^18",
    "react-dom": "^18",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.17",
    "dotenv-cli": "^11.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.35",
    "supabase": "^2.84.10",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.2.5",
    "typescript": "^5"
  }
}