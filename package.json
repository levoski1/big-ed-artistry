{
  "name": "big-ed-artistry",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:login": "supabase login",
    "db:link": "supabase link --project-ref $SUPABASE_PROJECT_REF",
    "db:migrate": "supabase db push --project-ref $SUPABASE_PROJECT_REF",
    "db:backup": "supabase db dump --project-ref $SUPABASE_PROJECT_REF -f supabase/backups/backup_$(date +%Y%m%d_%H%M%S).sql",
    "db:backup:data": "supabase db dump --project-ref $SUPABASE_PROJECT_REF --data-only -f supabase/backups/data_$(date +%Y%m%d_%H%M%S).sql",
    "db:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_REF > src/lib/types/database.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "next": "14.2.5",
    "react": "^18",
    "react-dom": "^18",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.17",
    "dotenv-cli": "^11.0.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
